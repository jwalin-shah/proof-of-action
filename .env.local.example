# Proof-of-Action — env template for judges / first-time cloners.
# Copy to .env.local (gitignored) and edit. Everything here has a working
# default; set only what you want to change.

# ─── Redis (local, required) ──────────────────────────────────────────
REDIS_PORT=6390
REDIS_PRIVATE_PW=privpw
REDIS_PUBLIC_PW=pubpw

# Enable mTLS after running ./scripts/tls-bootstrap.sh
# POA_REDIS_TLS=on
# POA_REDIS_TLS_CA=private/tls/ca.crt
# POA_REDIS_TLS_CERT=private/tls/agent.crt
# POA_REDIS_TLS_KEY=private/tls/agent.key

# ─── Master key (private envelope) ────────────────────────────────────
# Prefer Keychain: ./scripts/keygen.sh --keychain  (macOS only)
# Env fallback:    ./scripts/keygen.sh             (appends POA_MASTER_KEY)
# POA_MASTER_KEY=<64-hex-chars>

# ─── InsForge (public plane, required for dashboard + RLS) ────────────
POA_INSFORGE_URL=https://q7haa32f.us-east.insforge.app
POA_INSFORGE_EMAIL=demo@proof-of-action.local
POA_INSFORGE_PASSWORD=demoPass!ProofOfAction2026
# Optional: email notification when a draft is queued for human review
# POA_REVIEW_NOTIFY_EMAIL=you@example.com

# ─── Private LLM backend (pick one; falls back to template if none) ───
# Pluggable /api/chat endpoint (Akash Ollama, Venice.ai, Near AI, vLLM, LM Studio, laptop Ollama)
# POA_LLM=ollama
# POA_OLLAMA_URL=https://<your-endpoint>
# POA_OLLAMA_MODEL=llama3.1:8b
# POA_TCB_LABEL=remote_ollama_akash  # optional, surfaces in action log

# Or use Anthropic Claude (documented as inside the TCB)
# ANTHROPIC_API_KEY=<your-anthropic-key>

# ─── Guild audit (optional; CLI auto-detected) ────────────────────────
# GUILD_TOKEN=<bearer>
# GUILD_ENDPOINT=https://api.guild.ai/v1/workflows/runs

# ─── Input source (default: fixtures; needs allowlist to use gmail) ───
POA_SOURCE=fixture
POA_FIXTURE=fixtures/adversarial_threads.json
